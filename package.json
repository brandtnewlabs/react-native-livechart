{
  "name": "react-native-livechart-expo-example",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:lib": "jest packages/react-native-livechart",
    "test:coverage": "jest --coverage",
    "build:lib": "npm run build -w react-native-livechart",
    "build:lib:types:watch": "npm run build:types:watch -w react-native-livechart",
    "pack:lib": "npm pack -w react-native-livechart",
    "verify": "npm run typecheck && npm run lint && npm test",
    "verify:coverage": "npm run typecheck && npm run lint && npm run test:coverage",
    "prepare": "husky",
    "doctor": "npx react-doctor@latest",
    "docs": "cd docs && npx mint@latest dev"
  },
  "dependencies": {
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo-google-fonts/plus-jakarta-sans": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@legendapp/list": "^3.0.4",
    "@shopify/react-native-skia": "2.6.4",
    "@types/jest": "29.5.14",
    "expo": "^56.0.12",
    "expo-blur": "~56.0.3",
    "expo-constants": "~56.0.18",
    "expo-font": "~56.0.7",
    "expo-haptics": "~56.0.3",
    "expo-image": "~56.0.11",
    "expo-linking": "~56.0.14",
    "expo-router": "~56.2.11",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "jest": "~29.7.0",
    "jest-expo": "~56.0.5",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-livechart": "file:packages/react-native-livechart",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.14",
    "babel-preset-expo": "~56.0.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~56.0.4",
    "husky": "^9.1.7",
    "react-doctor": "^0.2.16",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  },
  "expo": {
    "install": {
      "exclude": [
        "@shopify/react-native-skia"
      ]
    }
  }
}

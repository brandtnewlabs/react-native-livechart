{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "react-native-livechart",
  "description": "High-performance live line and candlestick charts for React Native, built on Skia and Reanimated.",
  "colors": {
    "primary": "#3323E6",
    "light": "#5C4FEB",
    "dark": "#291CC3"
  },
  "fonts": {
    "heading": {
      "family": "Plus Jakarta Sans",
      "weight": 600
    },
    "body": {
      "family": "Plus Jakarta Sans",
      "weight": 400
    }
  },
  "favicon": "/favicon.png",
  "logo": {
    "light": "/logo.svg",
    "dark": "/logo-dark.svg"
  },
  "icons": {
    "library": "fontawesome"
  },
  "redirects": [
    {
      "source": "/guides/markers-and-references",
      "destination": "/guides/markers-and-trades"
    }
  ],
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": ["index", "installation", "quickstart"]
          },
          {
            "group": "Chart types",
            "pages": [
              "guides/line-and-area",
              "guides/candlestick",
              "guides/multi-series",
              "guides/sparklines"
            ]
          },
          {
            "group": "Interaction",
            "pages": [
              "guides/scrubbing",
              "guides/order-ticket",
              "guides/time-scroll"
            ]
          },
          {
            "group": "Annotations & overlays",
            "pages": [
              "guides/markers-and-trades",
              "guides/reference-lines-and-bands",
              "guides/overlay-bridge"
            ]
          },
          {
            "group": "Dynamic styling & effects",
            "pages": [
              "guides/momentum-and-degen",
              "guides/threshold",
              "guides/segments"
            ]
          },
          {
            "group": "Styling & theming",
            "pages": [
              "guides/theming",
              "guides/badge-styling",
              "guides/axes-and-grid",
              "guides/extrema-labels",
              "guides/android-surface-rendering"
            ]
          },
          {
            "group": "Live data & engine",
            "pages": [
              "guides/playback",
              "guides/historical-data",
              "guides/states-and-formatting",
              "guides/transitions"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Components",
            "pages": [
              "api-reference/livechart",
              "api-reference/livechart-series"
            ]
          },
          {
            "group": "Hooks, utilities & types",
            "pages": [
              "api-reference/hooks-and-utilities",
              "api-reference/types"
            ]
          }
        ]
      },
      {
        "tab": "Showcase",
        "groups": [
          {
            "group": "Real-app recreations",
            "pages": ["showcase/index"]
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "npm",
        "href": "https://www.npmjs.com/package/react-native-livechart"
      }
    ],
    "primary": {
      "type": "button",
      "label": "GitHub",
      "href": "https://github.com/brandtnewlabs/react-native-livechart"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/brandtnewlabs/react-native-livechart"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  }
}

{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits"
  ],
  "schedule": ["before 6am on monday"],
  "labels": ["dependencies"],
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"]
  },
  "packageRules": [
    {
      "description": "Library peer dependencies (RN, Skia, Reanimated, Worklets, Gesture Handler) are the consumer's choice — never bump them here.",
      "matchDepTypes": ["peerDependencies"],
      "enabled": false
    },
    {
      "description": "Group non-major devDependencies into a single review PR.",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "dev dependencies (non-major)"
    },
    {
      "description": "Group GitHub Actions bumps into a single review PR.",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    },
    {
      "description": "Flag React Native ecosystem majors for extra review.",
      "matchPackageNames": [
        "expo",
        "react",
        "react-native",
        "@shopify/react-native-skia",
        "react-native-reanimated",
        "react-native-gesture-handler",
        "react-native-worklets"
      ],
      "matchUpdateTypes": ["major"],
      "addLabels": ["needs-attention"]
    }
  ]
}
